datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String    // Ensure this is encrypted in your app logic
  createdAt DateTime  @default(now())
  editedAt  DateTime  @default(now()) @updatedAt

  // Define the relation to Workout
  workouts  Workout[]
}

model Workout {
  id           Int      @id @default(autoincrement())
  equipment    String
  duration     Int
  checkin      DateTime
  calories     Int      @default(0)
  weightLifted Int?     // Optional field
  distance     Float?   // Optional field
  repetitions  Int?     // Optional field
  user_id      Int

  createdAt    DateTime @default(now())
  editedAt     DateTime @default(now()) @updatedAt

  user         User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
}
