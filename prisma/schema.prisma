datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  email          String          @unique
  password       String          // Ensure encryption in app logic
  createdAt      DateTime        @default(now())
  userWorkouts   UserWorkout[]   // One-to-many relationship
  workoutPlans   WorkoutPlan[]   // One-to-many relationship
}

model WorkoutPlan {
  id             Int     @id @default(autoincrement())
  checkin        DateTime  @default(now())
  weight         Int
  updateWeighIn  Int
  workoutReview  String? 
  checkout      DateTime  @default(now())
  userPlanId     Int @unique
  profilePlan ProfilePlan[] 
  user User @relation(fields: [userPlanId], references: [id])
}

model ProfilePlan {
  id Int @id @default(autoincrement())
  firstName String 
  lastName String 
  email String
  homeClub String?
  memberSince DateTime?
  cellPhone String?
  city String?
  zipPostal String?
  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id]) 
  workoutPlanId Int @unique
}

model UserWorkout {
  id                Int                  @id @default(autoincrement())
  userId            Int
  dayOfWeek         String
  createdAt         DateTime             @default(now())
  editedAt          DateTime             @default(now())
  completed         Boolean
  favoritedExercise FavoritedExercise[]   @relation("UserWorkoutFavoritedExercuses")

  user User @relation(fields: [userId], references: [id])
}

model FavoritedExercise {
  id               Int                  @id @default(autoincrement())
  name             String               @unique
  equipment        String  
  gifUrl           String
  instructions     String
  secondaryMuscles String
  target           String
  userWorkout     UserWorkout[]        @relation("UserWorkoutFavoritedExercuses")
}