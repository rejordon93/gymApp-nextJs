datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  email          String          @unique
  password       String          // Ensure encryption in app logic
  createdAt      DateTime        @default(now())
  userWorkouts   UserWorkout[]   // One-to-many relationship
  workoutPlans   WorkoutPlan[]   // One-to-many relationship
}

model WorkoutPlan {
  id             Int     @id @default(autoincrement())
  userPlanId     Int
  checkin        DateTime  @default(now())
  weight         Int
  updateWeighIn  Int
  workoutReview  String? // Ensure this is defined as optional (nullable) if you allow empty reviews
  checkout      DateTime  @default(now())

  user User @relation(fields: [userPlanId], references: [id])
}


model UserWorkout {
  id                Int                  @id @default(autoincrement())
  userId            Int
  dayOfWeek         String
  createdAt         DateTime             @default(now())
  editedAt          DateTime             @default(now())
  completed         Boolean
  favoritedExercise FavoritedExercise[]   @relation("UserWorkoutFavoritedExercuses")

  user User @relation(fields: [userId], references: [id])
}

model FavoritedExercise {
  id               Int                  @id @default(autoincrement())
  name             String
  equipment        String
  gifUrl           String
  instructions     String
  secondaryMuscles String
  target           String
  userWorkout     UserWorkout[]        @relation("UserWorkoutFavoritedExercuses")
}
