datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String    // Ensure this is encrypted in your app logic
  createdAt DateTime  @default(now())
  editedAt  DateTime  @default(now()) @updatedAt

  // Define the relation to Workout
  workouts  Workout[]
  favoriteWorkout FavoriteWorkout[]
}

model Workout {
  id           Int      @id @default(autoincrement())
  equipment    String?
  duration     Int?
  checkin      DateTime
  checkout     DateTime?
  calories     Int?      @default(0)
  weightLifted Int?     // Optional field
  distance     Float?   // Optional field
  repetitions  Int?     // Optional field
  user_id      Int

  createdAt    DateTime @default(now())
  editedAt     DateTime @default(now()) @updatedAt

  user         User     @relation(fields: [user_id], references: [id])


  @@index([user_id])
}

model FavoriteWorkout {
  id             Int      @id @default(autoincrement()) // Primary key
  bodyPart       String?  // Optional field
  equipment      String?  // Optional field
  gifUrl         String?  // Optional field
  instructions   String[]   // Required field
  name           String   // Required field
  secondaryMuscles String[] // Optional field
  target         String?  // Optional field
  user_id        Int     // Foreign key reference
 
  user User @relation(fields: [user_id], references: [id]) // Relation to User

  @@map("favorite_workouts") // Optional: If the database table name differs
}
