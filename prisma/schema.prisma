datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int             @id @default(autoincrement())
  username      String          @unique
  email         String          @unique
  password      String          // Ensure encryption in app logic
  createdAt     DateTime        @default(now())
  userWorkouts  UserWorkout[]   // One-to-many relationship
  workoutPlans  WorkoutPlan[]   // One-to-many relationship
  profilePlan   ProfilePlan?    // One-to-one relationship
}

model ProfilePlan {
  id        Int     @id @default(autoincrement())
  firstName String
  lastName  String
  homeClub String?
  memberSince String?
  currentStatus String?
  cellPhone String?
  city String?
  state String?
  zipCode String?
  userId    Int?    @unique
  user      User?   @relation(fields: [userId], references: [id])
}


model WorkoutPlan {
  id            Int              @id @default(autoincrement())
  checkin       DateTime         @default(now())
  weight        Int
  updateWeighIn Int
  workoutReview String? 
  checkout      DateTime         @default(now())
  userPlanId    Int              @unique
  user          User             @relation(fields: [userPlanId], references: [id])
  userWorkouts  UserWorkout[]    @relation("WorkoutToUserWorkout")
}

model UserWorkout {
  id                Int                 @id @default(autoincrement())
  userId            Int
  dayOfWeek         String
  createdAt         DateTime            @default(now())
  editedAt          DateTime            @default(now())
  completed         Boolean
  user              User                @relation(fields: [userId], references: [id])
  workoutPlans      WorkoutPlan[]       @relation("WorkoutToUserWorkout") // Many-to-many relationship
  favoritedExercise FavoritedExercise[] @relation("UserWorkoutFavoritedExercises")
}

model FavoritedExercise {
  id               Int                  @id @default(autoincrement())
  name             String               @unique
  equipment        String
  gifUrl           String
  instructions     String
  secondaryMuscles String
  target           String
  userWorkouts     UserWorkout[]        @relation("UserWorkoutFavoritedExercises")
}
